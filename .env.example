# Environment template

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Map tiles (optional — defaults to OpenStreetMap raster)
NEXT_PUBLIC_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# AI (server-side only) — auto tries free/local providers, then grounded MADIA answers
AI_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_MS=90000
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Payment (test mode default for local dev)
MADIA_PAYMENT_MODE=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# Local development roles (comma-separated emails)
MADIA_DEV_ADMIN_EMAILS=admin@madia.local
MADIA_DEV_VALIDATOR_EMAILS=
MADIA_DEV_VALIDATOR_MAP=validator@caramoan.gov:MADIA-MUN-CAR
MADIA_DEV_OWNER_MAP=owner@caramoan.gov:MADIA-CAR-ACC-001

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
MADIA_DEFAULT_TIMEZONE=Asia/Manila
MADIA_DEFAULT_CURRENCY=PHP

# Data paths (optional overrides)
MADIA_REPOSITORY_DIR=./data/repository
MADIA_GEOJSON_DIR=./data/geojson
MADIA_RUNTIME_CACHE=./data/cache/madia-runtime.json
