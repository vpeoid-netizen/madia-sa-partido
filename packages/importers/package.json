{
  "name": "@madia/importers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "madia-import": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "import:production": "node dist/cli.js --mode=production",
    "import:dry-run": "node dist/cli.js --mode=dry-run",
    "test": "node --experimental-vm-modules node_modules/vitest/vitest.mjs run"
  },
  "dependencies": {
    "@madia/domain": "*",
    "csv-parse": "^5.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.0.9"
  }
}
